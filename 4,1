#include <Arduino.h>
#include "FS.h"
#include <LittleFS.h>

// Параметри дослідження
int freqs[] = {240, 160, 80, 40};
int sizes[] = {50, 100, 500, 1000};
String types[] = {"int", "float", "double", "char"};

// --- Структури Бінарного Дерева ---
template <typename T>
struct Node {
    T data;
    Node *left, *right;
    Node(T val) : data(val), left(nullptr), right(nullptr) {}
};

template <typename T>
Node<T>* insertNode(Node<T>* root, T val) {
    if (!root) return new Node<T>(val);
    if (val < root->data) root->left = insertNode(root->left, val);
    else root->right = insertNode(root->right, val);
    return root;
}

template <typename T>
void deleteTree(Node<T>* root) {
    if (!root) return;
    deleteTree(root->left);
    deleteTree(root->right);
    delete root;
}

// --- Алгоритм QuickSort ---
template <typename T>
void quickSort(T arr[], int left, int right) {
    int i = left, j = right;
    T pivot = arr[(left + right) / 2];
    while (i <= j) {
        while (arr[i] < pivot) i++;
        while (arr[j] > pivot) j--;
        if (i <= j) {
            T tmp = arr[i];
            arr[i] = arr[j];
            arr[j] = tmp;
            i++; j--;
        }
    }
    if (left < j) quickSort(arr, left, j);
    if (i < right) quickSort(arr, i, right);
}

// --- Функція запису у файл ---
void saveToFS(int f, int s, String t, String a, uint32_t time, size_t mem) {
    File file = LittleFS.open("/results.csv", FILE_APPEND);
    if (file) {
        file.printf("%d,%d,%s,%s,%u,%u\n", f, s, t.c_str(), a.c_str(), time, mem);
        file.close();
    }
}

// --- Тестовий запуск ---
template <typename T>
void runBatch(int f, int s, String typeName) {
    setCpuFrequencyMhz(f);
    
    // 1. Тест QuickSort
    T* arr = new T[s];
    for (int i = 0; i < s; i++) arr[i] = (T)(random(0, 10000) / 3.3);
    
    uint32_t start = micros();
    quickSort(arr, 0, s - 1);
    uint32_t diff = micros() - start;
    saveToFS(f, s, typeName, "QuickSort", diff, sizeof(T) * s);
    delete[] arr;

    // 2. Тест Binary Tree
    Node<T>* root = nullptr;
    size_t memBefore = ESP.getFreeHeap();
    start = micros();
    for (int i = 0; i < s; i++) {
        root = insertNode(root, (T)(random(0, 10000) / 3.3));
    }
    diff = micros() - start;
    size_t memUsed = memBefore - ESP.getFreeHeap();
    saveToFS(f, s, typeName, "BinaryTree", diff, memUsed);
    deleteTree(root);
}

void setup() {
    Serial.begin(115200);
    if (!LittleFS.begin(true)) return;
    
    LittleFS.remove("/results.csv"); // Очищення старого файлу
    File file = LittleFS.open("/results.csv", FILE_WRITE);
    file.println("Frequency,Size,Type,Algorithm,Time_us,Memory_bytes");
    file.close();

    Serial.println("Тестування розпочато... Зачекайте декілька хвилин.");

    for (int f : freqs) {
        for (int s : sizes) {
            runBatch<int>(f, s, "int");
            runBatch<float>(f, s, "float");
            runBatch<double>(f, s, "double");
            runBatch<char>(f, s, "char");
        }
    }

    // Вивід результатів після завершення на стабільній частоті
    setCpuFrequencyMhz(240);
    delay(1000);
    Serial.println("\n--- РЕЗУЛЬТАТИ ДОСЛІДЖЕННЯ (CSV) ---");
    
    File results = LittleFS.open("/results.csv", FILE_READ);
    while (results.available()) {
        Serial.write(results.read());
    }
    results.close();
    Serial.println("--- КІНЕЦЬ ФАЙЛУ ---");
}

void loop() {}
